<footer class="footer">
  <div class="footer__container">
    <div class="footer__main">
      {%- comment -%} Newsletter - Left Side {%- endcomment -%}
      <div class="footer__newsletter">
        <h3 class="footer__heading">{{ section.settings.newsletter_heading }}</h3>
        <p class="footer__text">{{ section.settings.newsletter_text }}</p>
        {% form 'customer', class: 'footer__newsletter-form' %}
          <input
            type="email"
            name="contact[email]"
            placeholder="Enter your email"
            required
            class="footer__newsletter-input"
          >
          <button type="submit" class="footer__newsletter-btn">
            Subscribe
          </button>
        {% endform %}
      </div>

      {%- comment -%} Contact Us - Right Side {%- endcomment -%}
      <div class="footer__contact">
        <h3 class="footer__heading">Contact Us</h3>
        {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}" class="footer__contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            {{ section.settings.contact_email }}
          </a>
        {%- endif -%}
        {%- if section.settings.contact_phone != blank -%}
          <a href="tel:{{ section.settings.contact_phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}" class="footer__contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            {{ section.settings.contact_phone }}
          </a>
        {%- endif -%}
        {%- if section.settings.contact_address != blank -%}
          <p class="footer__contact-item footer__contact-item--address">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            {{ section.settings.contact_address }}
          </p>
        {%- endif -%}
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </div>

      <div class="footer__links">
        {% for link in section.settings.menu.links %}
          {{ link.title | link_to: link.url }}
        {% endfor %}
      </div>

      <div class="footer__payment">
        {% if section.settings.show_payment_icons %}
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-background-secondary);
    border-top: 1px solid var(--color-border);
    padding: 3rem var(--page-margin) 2rem;
    margin-top: 4rem;
  }
  .footer__container {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .footer__main {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .footer__heading {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--color-foreground);
  }
  .footer__text {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0 0 1rem 0;
    max-width: 350px;
  }
  .footer__newsletter {
    flex: 1;
    max-width: 450px;
  }
  .footer__newsletter-form {
    display: flex;
    gap: 0;
  }
  .footer__newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: var(--style-border-radius-inputs, 4px) 0 0 var(--style-border-radius-inputs, 4px);
    background-color: var(--color-background);
    color: var(--color-foreground);
  }
  .footer__newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .footer__newsletter-btn {
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    background-color: var(--color-accent);
    color: var(--color-accent-text);
    border: none;
    border-radius: 0 var(--style-border-radius-inputs, 4px) var(--style-border-radius-inputs, 4px) 0;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .footer__newsletter-btn:hover {
    background-color: var(--color-accent-hover);
  }
  .footer__contact {
    text-align: right;
  }
  .footer__contact-item {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-foreground);
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
  }
  a.footer__contact-item:hover {
    color: var(--color-accent);
  }
  .footer__contact-item--address {
    margin: 0;
    color: var(--color-text-secondary);
  }
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer__copyright {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
  .footer__links {
    display: flex;
    gap: 1.5rem;
  }
  .footer__links a {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer__links a:hover {
    color: var(--color-foreground);
  }
  .footer__payment {
    display: flex;
    gap: 0.5rem;
  }
  .footer__payment svg {
    width: 38px;
    height: 24px;
  }

  @media (max-width: 768px) {
    .footer__main {
      flex-direction: column;
      gap: 2rem;
    }
    .footer__newsletter {
      max-width: 100%;
    }
    .footer__contact {
      text-align: left;
    }
    .footer__contact-item {
      justify-content: flex-start;
    }
    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
  @media (max-width: 500px) {
    .footer__newsletter-form {
      flex-direction: column;
      gap: 0.75rem;
    }
    .footer__newsletter-input {
      border-right: 1px solid var(--color-border);
      border-radius: var(--style-border-radius-inputs, 4px);
    }
    .footer__newsletter-btn {
      border-radius: var(--style-border-radius-inputs, 4px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the Loop"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Subscribe for exclusive deals, new arrivals, and Mini news."
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "info@willmekauto.com"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone",
      "default": "(555) 123-4567"
    },
    {
      "type": "textarea",
      "id": "contact_address",
      "label": "Address",
      "default": "123 Mini Lane, Auto City, CA 90210"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ]
}
{% endschema %}
