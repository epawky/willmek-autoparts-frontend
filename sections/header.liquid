<header class="header">
  <div class="header__inner">
    {%- comment -%} Logo {%- endcomment -%}
    <div class="header__logo">
      <a href="{{ routes.root_url }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="Willmek Auto Parts"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
          >
        {%- else -%}
          <span class="header__logo-text">Willmek Auto Parts</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Navigation Menu with Dropdowns {%- endcomment -%}
    <nav class="header__nav">
      <ul class="header__menu">
        <li class="header__menu-item header__menu-item--has-dropdown">
          <a href="/pages/mini-parts">Mini Parts</a>
          <ul class="header__dropdown">
            <li><a href="/collections/classic-mini">Classic Mini (1959-2000)</a></li>
            <li class="header__dropdown-item--has-submenu">
              <a href="/collections/gen-1">Gen 1 (2002-2006)</a>
              <ul class="header__submenu">
                <li><a href="/collections/r50">R50 One/Cooper</a></li>
                <li><a href="/collections/r53">R53 Cooper S</a></li>
                <li><a href="/collections/r52">R52 Convertible</a></li>
                <li><a href="/collections/r52-s">R52 Convertible S</a></li>
                <li><a href="/collections/r53-gp">R53 GP</a></li>
              </ul>
            </li>
            <li class="header__dropdown-item--has-submenu">
              <a href="/collections/gen-2">Gen 2 (2007-2013)</a>
              <ul class="header__submenu">
                <li><a href="/collections/r55">R55 Clubman</a></li>
                <li><a href="/collections/r55-s">R55 Clubman S</a></li>
                <li><a href="/collections/r56">R56 Hardtop</a></li>
                <li><a href="/collections/r56-s">R56 Hardtop S/JCW</a></li>
                <li><a href="/collections/r56-gp">R56 GP</a></li>
                <li><a href="/collections/r57">R57 Convertible</a></li>
                <li><a href="/collections/r57-s">R57 Convertible S</a></li>
                <li><a href="/collections/r58">R58 Coupe</a></li>
                <li><a href="/collections/r58-s">R58 Coupe S/JCW</a></li>
                <li><a href="/collections/r59">R59 Roadster</a></li>
                <li><a href="/collections/r59-s">R59 Roadster S/JCW</a></li>
