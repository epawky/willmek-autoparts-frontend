{% stylesheet %}
  .category-cards {
    padding: 4rem var(--page-margin);
    background-color: var(--color-background);
  }
  .category-cards__container {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .category-cards__title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 2.5rem 0;
    color: var(--color-foreground);
  }
  .category-cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .category-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-background-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-foreground);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px var(--color-shadow);
    border-color: var(--color-accent);
  }
  .category-card__image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-pepper);
    padding: 1.5rem;
  }
  .category-card__image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }
  .category-card:hover .category-card__image img {
    transform: scale(1.05);
  }
  .category-card__content {
    padding: 1.25rem 1.5rem 1.5rem;
  }
  .category-card__name {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
  }
  .category-card__description {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .category-cards {
      padding: 2.5rem var(--page-margin);
    }
    .category-cards__title {
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .category-cards__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "image_picker",
      "id": "placeholder_image",
      "label": "Placeholder image",
      "info": "Used for all cards until individual images are set"
    }
  ],
  "presets": [
    {
      "name": "Category Cards"
    }
  ]
}
{% endschema %}
