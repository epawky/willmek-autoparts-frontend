<section class="contact">
  <div class="contact__container">
    <div class="contact__header">
      <h1 class="contact__title">{{ section.settings.heading }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="contact__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="contact__content">
      <div class="contact__form-wrapper">
        {%- form 'contact', class: 'contact__form' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact__success">
              <p>Thanks for contacting us! We'll get back to you as soon as possible.</p>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="contact__errors">
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {%- endif -%}

          <div class="contact__form-grid">
            <div class="contact__field">
              <label for="contact-name" class="contact__label">Name *</label>
              <input
                type="text"
                id="contact-name"
                name="contact[name]"
                class="contact__input"
                required
                autocomplete="name"
              >
            </div>

            <div class="contact__field">
              <label for="contact-email" class="contact__label">Email *</label>
              <input
                type="email"
                id="contact-email"
                name="contact[email]"
                class="contact__input"
                required
                autocomplete="email"
              >
            </div>

            <div class="contact__field">
              <label for="contact-phone" class="contact__label">Phone</label>
              <input
                type="tel"
                id="contact-phone"
                name="contact[phone]"
                class="contact__input"
                autocomplete="tel"
              >
            </div>

            <div class="contact__field">
              <label for="contact-subject" class="contact__label">Subject</label>
              <select id="contact-subject" name="contact[subject]" class="contact__input contact__select">
                <option value="General Inquiry">General Inquiry</option>
                <option value="Parts Question">Parts Question</option>
                <option value="Order Status">Order Status</option>
                <option value="Returns & Refunds">Returns & Refunds</option>
                <option value="Wholesale Inquiry">Wholesale Inquiry</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="contact__field">
              <label for="contact-year" class="contact__label">Year</label>
              <select id="contact-year" name="contact[year]" class="contact__input contact__select">
                <option value="">Select Year</option>
                {%- for year in (2002..2026) reversed -%}
                  <option value="{{ year }}">{{ year }}</option>
                {%- endfor -%}
                <option value="Pre-2002">Pre-2002 (Classic)</option>
              </select>
            </div>

            <div class="contact__field">
              <label for="contact-make" class="contact__label">Make</label>
              <select id="contact-make" name="contact[make]" class="contact__input contact__select">
                <option value="">Select Make</option>
                <option value="MINI">MINI</option>
                <option value="Austin">Austin</option>
                <option value="Morris">Morris</option>
                <option value="Rover">Rover</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="contact__field">
              <label for="contact-model" class="contact__label">Model</label>
              <select id="contact-model" name="contact[model]" class="contact__input contact__select">
                <option value="">Select Model</option>
                <optgroup label="Gen 3 (2014+)">
                  <option value="F54 Clubman">F54 Clubman</option>
                  <option value="F55 Hardtop 4-Door">F55 Hardtop 4-Door</option>
                  <option value="F56 Hardtop 2-Door">F56 Hardtop 2-Door</option>
                  <option value="F57 Convertible">F57 Convertible</option>
                  <option value="F60 Countryman">F60 Countryman</option>
                </optgroup>
                <optgroup label="Gen 2 (2007-2013)">
                  <option value="R55 Clubman">R55 Clubman</option>
                  <option value="R56 Hardtop">R56 Hardtop</option>
                  <option value="R57 Convertible">R57 Convertible</option>
                  <option value="R58 Coupe">R58 Coupe</option>
                  <option value="R59 Roadster">R59 Roadster</option>
                  <option value="R60 Countryman">R60 Countryman</option>
                  <option value="R61 Paceman">R61 Paceman</option>
                </optgroup>
                <optgroup label="Gen 1 (2002-2006)">
                  <option value="R50 One/Cooper">R50 One/Cooper</option>
                  <option value="R52 Convertible">R52 Convertible</option>
                  <option value="R53 Cooper S">R53 Cooper S</option>
                </optgroup>
                <optgroup label="Classic">
                  <option value="Classic Mini">Classic Mini</option>
                </optgroup>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="contact__field">
              <label for="contact-engine" class="contact__label">Engine</label>
              <select id="contact-engine" name="contact[engine]" class="contact__input contact__select">
                <option value="">Select Engine</option>
                <optgroup label="Gen 3">
                  <option value="B38 1.5L 3-cyl Turbo">B38 1.5L 3-cyl Turbo</option>
                  <option value="B46 2.0L 4-cyl Turbo">B46 2.0L 4-cyl Turbo</option>
                  <option value="B48 2.0L 4-cyl Turbo (S/JCW)">B48 2.0L 4-cyl Turbo (S/JCW)</option>
                </optgroup>
                <optgroup label="Gen 2">
                  <option value="N12 1.6L">N12 1.6L</option>
                  <option value="N14 1.6L Turbo">N14 1.6L Turbo</option>
                  <option value="N16 1.6L">N16 1.6L</option>
                  <option value="N18 1.6L Turbo">N18 1.6L Turbo</option>
                </optgroup>
                <optgroup label="Gen 1">
                  <option value="W10 1.6L">W10 1.6L</option>
                  <option value="W11 1.6L Supercharged">W11 1.6L Supercharged</option>
                </optgroup>
                <optgroup label="Classic">
                  <option value="A-Series">A-Series</option>
                </optgroup>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="contact__field">
              <label for="contact-exterior" class="contact__label">Exterior Color</label>
              <input
                type="text"
                id="contact-exterior"
                name="contact[exterior_color]"
                class="contact__input"
                placeholder="e.g., Chili Red, Pepper White"
              >
            </div>

            <div class="contact__field">
              <label for="contact-interior" class="contact__label">Interior Color</label>
              <input
                type="text"
                id="contact-interior"
                name="contact[interior_color]"
                class="contact__input"
                placeholder="e.g., Carbon Black, Lounge Leather"
              >
            </div>

            <div class="contact__field contact__field--full">
              <label for="contact-vin" class="contact__label">VIN (if applicable)</label>
              <input
                type="text"
                id="contact-vin"
                name="contact[vin]"
                class="contact__input contact__input--mono"
                maxlength="17"
                placeholder="17-character VIN"
              >
            </div>

            <div class="contact__field contact__field--full">
              <label for="contact-message" class="contact__label">Message *</label>
              <textarea
                id="contact-message"
                name="contact[body]"
                class="contact__input contact__textarea"
                rows="6"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="contact__submit">
            Send Message
          </button>
        {%- endform -%}
      </div>

      <div class="contact__info">
        <div class="contact__info-section">
          <h3 class="contact__info-title">Contact Info</h3>
          {%- if section.settings.email != blank -%}
            <p class="contact__info-item">
              <span class="contact__info-label">Email:</span>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </p>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <p class="contact__info-item">
              <span class="contact__info-label">Phone:</span>
              <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}">{{ section.settings.phone }}</a>
            </p>
          {%- endif -%}
        </div>

        {%- if section.settings.address != blank -%}
          <div class="contact__info-section">
            <h3 class="contact__info-title">Location</h3>
            <p class="contact__info-item">{{ section.settings.address | newline_to_br }}</p>
          </div>
        {%- endif -%}

        {%- if section.settings.hours != blank -%}
          <div class="contact__info-section">
            <h3 class="contact__info-title">Hours</h3>
            <p class="contact__info-item">{{ section.settings.hours | newline_to_br }}</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .contact {
    padding: 4rem var(--page-margin);
    background-color: var(--color-background);
  }
  .contact__container {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .contact__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .contact__title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    color: var(--color-foreground);
  }
  .contact__subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .contact__content {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
  }
  .contact__form-wrapper {
    background-color: var(--color-background-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 2rem;
  }
  .contact__success {
    background-color: #d1fae5;
    border: 1px solid #10b981;
    border-radius: 6px;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }
  .contact__success p {
    margin: 0;
    color: #065f46;
  }
  [data-theme="dark"] .contact__success {
    background-color: rgba(16, 185, 129, 0.15);
  }
  [data-theme="dark"] .contact__success p {
    color: #6ee7b7;
  }
  .contact__errors {
    background-color: #fee2e2;
    border: 1px solid #ef4444;
    border-radius: 6px;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }
  .contact__errors p {
    margin: 0;
    color: #dc2626;
  }
  [data-theme="dark"] .contact__errors {
    background-color: rgba(239, 68, 68, 0.15);
  }
  [data-theme="dark"] .contact__errors p {
    color: #fca5a5;
  }
  .contact__form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .contact__field {
    display: flex;
    flex-direction: column;
  }
  .contact__field--full {
    grid-column: 1 / -1;
  }
  .contact__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }
  .contact__input {
    padding: 0.875rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-inputs, 4px);
    background-color: var(--color-background);
    color: var(--color-foreground);
    transition: border-color 0.2s ease;
  }
  .contact__input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .contact__input--mono {
    font-family: monospace;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .contact__select {
    cursor: pointer;
  }
  .contact__textarea {
    resize: vertical;
    min-height: 150px;
  }
  .contact__submit {
    margin-top: 1.5rem;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    background-color: var(--color-accent);
    color: var(--color-accent-text);
    border: none;
    border-radius: var(--style-border-radius-inputs, 4px);
    cursor: pointer;
    transition: background-color 0.2s ease;
    width: 100%;
  }
  .contact__submit:hover {
    background-color: var(--color-accent-hover);
  }
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact__info-section {
    background-color: var(--color-background-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .contact__info-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--color-foreground);
  }
  .contact__info-item {
    margin: 0 0 0.5rem 0;
    font-size: 0.95rem;
    color: var(--color-foreground);
    line-height: 1.6;
  }
  .contact__info-item:last-child {
    margin-bottom: 0;
  }
  .contact__info-label {
    color: var(--color-text-secondary);
  }
  .contact__info-item a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .contact__info-item a:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .contact__content {
      grid-template-columns: 1fr;
    }
    .contact__info {
      order: -1;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .contact__info-section {
      flex: 1;
      min-width: 200px;
    }
  }
  @media (max-width: 600px) {
    .contact {
      padding: 2.5rem var(--page-margin);
    }
    .contact__title {
      font-size: 1.75rem;
    }
    .contact__form-wrapper {
      padding: 1.5rem;
    }
    .contact__form-grid {
      grid-template-columns: 1fr;
    }
    .contact__info {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Have a question about parts, orders, or your Mini? We're here to help!"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "info@willmekautoparts.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "(555) 123-4567"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Mini Cooper Lane\nAutomotive District\nCity, State 12345"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Business hours",
      "default": "Monday - Friday: 9am - 6pm\nSaturday: 10am - 4pm\nSunday: Closed"
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
